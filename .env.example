# In Codespaces, OPENAI_API_KEY is injected from a repo/user secret — you do
# not need to create a .env file. For local runs, copy this file to `.env` and
# fill in the values. Never commit your real .env.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Which resident the assistant acts on behalf of for prompts like
# "What's my balance?". Valid IDs: R001..R012 (see tools_data/residents.json).
RESIDENT_ID=R001

# Tracing / telemetry: off by default for all frameworks. Flip any of these
# back to true if you want to inspect traces locally (LangSmith, OpenAI Agents
# SDK, CrewAI, OpenTelemetry exporters).
LANGCHAIN_TRACING_V2=false
LANGSMITH_TRACING=false
CREWAI_TRACING_ENABLED=false
OTEL_SDK_DISABLED=true
