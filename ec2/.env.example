# EC2 secrets for `docker compose up` — copy to .env, never commit.
# (The `aws-setup.sh deploy` script writes this file for you on the box.)

# Domain pointing at this EC2's public IP. Easiest is sslip.io which auto-
# resolves <dashed-ip>.sslip.io to that IP. Replace the placeholder below
# with your own EC2 public IP, dashes instead of dots.
INTERVIEW_DOMAIN=<your-ec2-ip-with-dashes>.sslip.io

# Email Let's Encrypt uses for cert expiry warnings.
ACME_EMAIL=you@example.com

# Random password for code-server login. Generate with: openssl rand -base64 24
CODE_SERVER_PASSWORD=replace-me

# Real OpenAI key the candidate's tools will use.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1
